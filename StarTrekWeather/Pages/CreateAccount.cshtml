@page
@model CreateAccountModel
@{
    ViewData["Title"] = "Create Account";
}

<section class="auth-hero">
    <div class="auth-hero-content">
        <div class="auth-card">
            <div class="auth-card-header">
                <p class="hero-eyebrow">STARFLEET PERSONNEL ENROLLMENT</p>
                <h1 class="auth-title">Create<br>Account</h1>
                <p class="auth-subtitle">Register your credentials with the Starfleet Meteorological Division.</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <form class="auth-form" method="post" autocomplete="off">
                <div class="auth-field">
                    <label class="auth-label" asp-for="Username">Username</label>
                    <input class="auth-input" asp-for="Username" placeholder="Cadet handle" required />
                </div>

                <div class="auth-field">
                    <label class="auth-label" asp-for="Password">Password</label>
                    <input class="auth-input" asp-for="Password" type="password" placeholder="••••••••" minlength="6" maxlength="20" required />
                    <span class="auth-hint">Security clearance: 6-20 characters.</span>
                </div>

                <button type="submit" class="auth-submit">Create Account</button>
            </form>
        </div>
    </div>
</section>
