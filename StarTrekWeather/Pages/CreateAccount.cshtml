@page
@model CreateAccountModel
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Create Account";
    var appMode = HttpContext.Session.GetString("AppMode") ?? "startrek";
}

<section class="auth-hero @(appMode == "pokemon" ? "pokemon-theme" : "")">
    <div class="auth-hero-content">
        <div class="auth-card">
            <div class="auth-card-header">
                <p class="hero-eyebrow">ACCOUNT SETUP</p>
                <h1 class="auth-title">Create<br>Account</h1>
                <p class="auth-subtitle">Create an account to save forecasts and favorite locations.</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <form class="auth-form" method="post" autocomplete="off">
                <div class="auth-field">
                    <label class="auth-label" asp-for="Username">Username</label>
                    <input class="auth-input" asp-for="Username" placeholder="Username" required />
                </div>

                <div class="auth-field">
                    <label class="auth-label" asp-for="Password">Password</label>
                    <input class="auth-input" asp-for="Password" type="password" placeholder="••••••••" minlength="6" maxlength="20" required />
                    <span class="auth-hint">Use 6-20 characters.</span>
                </div>

                <button type="submit" class="auth-submit">Create Account</button>
            </form>
        </div>
    </div>
</section>
