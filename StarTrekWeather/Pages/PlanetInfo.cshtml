@page
@model PlanetInfoModel
@{
ViewData["Title"] = "Planet Info";
}

<section class="planet-info-page">
    <div class="planet-info-overlay"></div>

    <div class="planet-info-content">
        <div class="planet-copy">
            <p class="planet-hero-label">Starfleet Planet Record</p>
            <h1 class="planet-hero-title">@Model.PlanetName</h1>
            <p class="planet-hero-subtitle">
                Atmospheric conditions and planetary registry data
            </p>

            <div class="planet-stats-card">
                <div class="planet-stat">
                    <span class="planet-stat-label">Mean Temperature</span>
                    <span class="planet-stat-value">@Model.MeanTemp</span>
                </div>

                <div class="planet-stat">
                    <span class="planet-stat-label">Atmospheric Pressure</span>
                    <span class="planet-stat-value">@Model.AtmosphericPressure</span>
                </div>

                <div class="planet-stat">
                    <span class="planet-stat-label">Solar System</span>
                    <span class="planet-stat-value">@Model.SolarSystem</span>
                </div>
            </div>
        </div>
    </div>
</section>