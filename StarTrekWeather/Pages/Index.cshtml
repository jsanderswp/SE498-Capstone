@page
@model IndexModel
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Home";
    var appMode = HttpContext.Session.GetString("AppMode") ?? "startrek";
    var isPokemonMode = appMode == "pokemon";
}


<section class="hero-section @(isPokemonMode ? "theme-pokemon" : "")" id="heroSection">
    <div class="hero-bg hero-bg-startrek"></div>
    <div class="hero-bg hero-bg-pokemon"></div>
    <div class="hero-content">
        <p class="hero-eyebrow">
    		@(isPokemonMode ? "POKEMON LOCATION FORECAST NETWORK" : "STARFLEET METEOROLOGICAL DIVISION")
		</p>

		<h1 class="hero-title">
    		@if (isPokemonMode)
    		{
        		@:Poke<br>Cast
    		}
    		else
    		{
        		@:Starfleet<br>Weather
    		}
		</h1>

		<p class="hero-subtitle">
    		@(isPokemonMode
        		? "Explore weather and landmarks across the Pokemon world."
        		: "Explore atmospheric conditions across the galaxy.")
		</p>


        <button type="button" class="theme-toggle" id="themeToggle"
                role="switch" aria-checked="false"
                aria-label="Switch between Star Trek and Pokémon themes">
            <span class="theme-toggle-icon theme-toggle-icon--left" aria-hidden="true">✦</span>
            <span class="theme-toggle-icon theme-toggle-icon--right" aria-hidden="true">◉</span>
            <span class="theme-toggle-knob"></span>
        </button>

        <div class="search-wrapper">
    <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input type="text" class="planet-search" placeholder="@(isPokemonMode ? "Search a Pokemon location..." : "Search a planet...")" id="planetSearch" autocomplete="off" />
    <button class="search-clear" id="clearSearch" aria-label="Clear search">&#x2715;</button>
    <ul class="search-dropdown" id="searchDropdown"></ul>
</div>

<script>
    let currentMode = '@(isPokemonMode ? "pokemon" : "startrek")';
    const input = document.getElementById('planetSearch');
    const clearBtn = document.getElementById('clearSearch');
    const dropdown = document.getElementById('searchDropdown');
    let debounceTimer;

    input.addEventListener('input', () => {
        const q = input.value.trim();
        clearBtn.style.opacity = q.length > 0 ? '1' : '0';
        clearTimeout(debounceTimer);
        if (q.length < 1) { hideDropdown(); return; }
        debounceTimer = setTimeout(() => {
            const isPokemon = document.getElementById('heroSection').classList.contains('theme-pokemon');
            if (isPokemon) {
                fetchPokemonSuggestions(q);
            } else {
                fetchSuggestions(q);
            }
        }, 200);
    });

    async function fetchSuggestions(q) {
        try {
            const res = await fetch(`/api/planetproxy/search?q=${encodeURIComponent(q)}`);
            const planets = await res.json();
            dropdown.innerHTML = '';
            if (planets.length === 0) { hideDropdown(); return; }
            planets.forEach(planet => {
                const li = document.createElement('li');
                li.className = 'search-dropdown-item';
                li.textContent = planet.name;
                li.addEventListener('click', () => {
                    window.location.href = `/PlanetInfo?planet=${encodeURIComponent(planet.name)}`;
                });
                dropdown.appendChild(li);
            });
            dropdown.classList.add('active');
        } catch (err) {
            console.error('Search error:', err);
        }
    }

    async function fetchPokemonSuggestions(q) {
        try {
            const res = await fetch(`/pokemonlocations/search?q=${encodeURIComponent(q)}`);
            const matches = await res.json();
            dropdown.innerHTML = '';
            if (matches.length === 0) { hideDropdown(); return; }
            matches.forEach(loc => {
                const li = document.createElement('li');
                li.className = 'search-dropdown-item';
                li.textContent = loc.name;
                li.addEventListener('click', () => {
                    const id = loc.locationId ?? loc.id ?? encodeURIComponent(loc.name || '');
                    window.location.href = `/PokemonLocationInfo?id=${id}`;
                });
                dropdown.appendChild(li);
            });
            dropdown.classList.add('active');
        } catch (err) {
            console.error('Pokemon search error:', err);
            hideDropdown();
        }
    }

    function hideDropdown() {
        dropdown.classList.remove('active');
        dropdown.innerHTML = '';
    }

    clearBtn.addEventListener('click', () => {
        input.value = '';
        clearBtn.style.opacity = '0';
        hideDropdown();
        input.focus();
    });

    input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
            const first = dropdown.querySelector('.search-dropdown-item');
            if (first) first.click();
        }
    });

    document.addEventListener('click', (e) => {
        if (!e.target.closest('.search-wrapper')) hideDropdown();
    });

    // Theme toggle: flips background crossfade, slider position, and hero copy
    const themeToggle = document.getElementById('themeToggle');
    const heroSection = document.getElementById('heroSection');
    const heroEyebrow = document.querySelector('.hero-eyebrow');
    const heroTitle = document.querySelector('.hero-title');
    const heroSubtitle = document.querySelector('.hero-subtitle');
    const searchInput = document.getElementById('planetSearch');
    const appTitlePrimary = document.getElementById('appTitlePrimary');
    const appTitleSecondary = document.getElementById('appTitleSecondary');
    const appDocumentTitle = document.getElementById('appDocumentTitle');

    const themeCopy = {
        startrek: {
            eyebrow: 'STARFLEET METEOROLOGICAL DIVISION',
            title: 'Starfleet<br>Weather',
            subtitle: 'Explore atmospheric conditions across the galaxy.',
            placeholder: 'Search a planet...'
        },
        pokemon: {
            eyebrow: 'POKEMON LOCATION FORECAST NETWORK',
            title: 'Poke<br>Cast',
            subtitle: 'Explore weather and landmarks across the Pokemon world.',
            placeholder: 'Search a Pokemon location...',
            navPrimary: 'POKE',
            navSecondary: 'CAST',
            appName: 'PokeCast'
        }
    };

    themeCopy.startrek.navPrimary = 'TREK';
    themeCopy.startrek.navSecondary = 'TEMP';
    themeCopy.startrek.appName = 'TrekTemp';

    if (currentMode === 'pokemon') {
        themeToggle.classList.add('is-on');
        themeToggle.setAttribute('aria-checked', 'true');
    }

    themeToggle.addEventListener('click', async () => {
        const isPokemon = heroSection.classList.toggle('theme-pokemon');
        currentMode = isPokemon ? 'pokemon' : 'startrek';
        themeToggle.classList.toggle('is-on', isPokemon);
        themeToggle.setAttribute('aria-checked', isPokemon ? 'true' : 'false');

        // Clear stale results from the previous source
        searchInput.value = '';
        clearBtn.style.opacity = '0';
        hideDropdown();

        // Fade copy out, swap, fade back in — synced halfway through the bg crossfade
        heroSection.classList.add('is-swapping');
        setTimeout(() => {
            const copy = isPokemon ? themeCopy.pokemon : themeCopy.startrek;
            heroEyebrow.innerHTML = copy.eyebrow;
            heroTitle.innerHTML = copy.title;
            heroSubtitle.innerHTML = copy.subtitle;
            searchInput.placeholder = copy.placeholder;
            if (appTitlePrimary && appTitleSecondary) {
                appTitlePrimary.textContent = copy.navPrimary;
                appTitleSecondary.textContent = copy.navSecondary;
            }
            if (appDocumentTitle) {
                const pageTitle = '@ViewData["Title"]';
                appDocumentTitle.textContent = `${pageTitle} - ${copy.appName}`;
                document.title = `${pageTitle} - ${copy.appName}`;
            }
            heroSection.classList.remove('is-swapping');
        }, 300);

        try {
            await fetch('/api/appmode', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ mode: currentMode })
            });
        } catch (err) {
            console.error('Failed to save app mode:', err);
        }
    });
</script>
