@page
@model UserPageModel
@{
    ViewData["Title"] = "My Profile";
}

<section class="user-hero">
    <div class="user-hero-content">
        <div class="user-greeting">
            <p class="hero-eyebrow">STARFLEET PERSONNEL FILE</p>
            <h1 class="user-title">Hello, <span class="username-highlight">@Model.Username</span>!</h1>
        </div>

        <div class="tab-panel active">
            <h2 class="auth-title">Saved Planets</h2>

            @if (Model.SavedPlanets.Count == 0)
            {
                <p class="auth-subtitle">You have not saved any planets yet.</p>
            }
            else
            {
                <div class="planet-grid">
                    @foreach (var planet in Model.SavedPlanets)
                    {
                        <a class="planet-card" href="/PlanetInfo?planet=@Uri.EscapeDataString(planet)">
                            <div class="planet-card-header">
                                <span class="planet-icon">🪐</span>
                                <h3 class="planet-name">@planet</h3>
                            </div>
                            <div class="planet-card-body">
                                <div class="planet-stat">
                                    <span class="stat-label">STATUS</span>
                                    <span class="stat-value condition-mild">Saved</span>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</section>