<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Star Trek Weather</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<header>
    <nav class="navbar navbar-expand-lg custom-navbar px-4">
        <div class="container-fluid">
            <a class="navbar-brand app-title" asp-page="/Index">Star Trek Weather</a>

            <div class="ms-auto d-flex gap-2">
                <a class="btn btn-outline-light" asp-page="/Login">Login</a>
                <a class="btn btn-primary" asp-page="/CreateAccount">Create Account</a>
            </div>
        </div>
    </nav>
</header>

<main class="container-fluid px-0">
    @RenderBody()
</main>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>