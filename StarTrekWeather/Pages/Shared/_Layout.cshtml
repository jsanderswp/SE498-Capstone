@using Microsoft.AspNetCore.Http
@{
    var currentUsername = Context.Session.GetString("Username");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TrekTemp</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Exo+2:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<header>
    <nav class="custom-navbar px-4">
        <div class="navbar-inner">
            <a class="app-title" href="/">
                <span class="title-trek">TREK</span><span class="title-temp">TEMP</span>
            </a>

            <div class="nav-links">
    		@if (string.IsNullOrWhiteSpace(currentUsername))
    		{
        		<a class="nav-btn nav-btn-ghost" href="/Login">Login</a>
        		<a class="nav-btn nav-btn-primary" href="/CreateAccount">Create Account</a>
    		}
    	else
    		{
    		<a class="nav-btn nav-btn-primary" href="/UserPage">@currentUsername</a>
    		<a class="nav-btn nav-btn-ghost" href="/Logout">Logout</a>
    		}
		</div>

        </div>
    </nav>
</header>

<main>
    @RenderBody()
</main>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>