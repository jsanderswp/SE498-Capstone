@page
@model LoginModel
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Login";
    var appMode = HttpContext.Session.GetString("AppMode") ?? "startrek";
}

<section class="auth-hero @(appMode == "pokemon" ? "pokemon-theme" : "")">
    <div class="auth-hero-content">
        <div class="auth-card">
            <div class="auth-card-header">
                <p class="hero-eyebrow">ACCOUNT ACCESS</p>
                <h1 class="auth-title">Login</h1>
                <p class="auth-subtitle">Sign in to continue exploring saved forecasts and locations.</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <form class="auth-form" method="post" autocomplete="off">
                <div class="auth-field">
                    <label class="auth-label" asp-for="Username">Username</label>
                    <input class="auth-input" asp-for="Username" placeholder="Username" required />
                </div>

                <div class="auth-field">
                    <label class="auth-label" asp-for="Password">Password</label>
                    <input class="auth-input" asp-for="Password" type="password" placeholder="••••••••" required />
                </div>

                <button type="submit" class="auth-submit">Login</button>
            </form>


        </div>
    </div>
</section>
