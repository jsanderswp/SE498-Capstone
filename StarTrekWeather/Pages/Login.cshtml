@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
}

<section class="auth-hero">
    <div class="auth-hero-content">
        <div class="auth-card">
            <div class="auth-card-header">
                <p class="hero-eyebrow">STARFLEET PERSONNEL ACCESS</p>
                <h1 class="auth-title">Login</h1>
                <p class="auth-subtitle">Authenticate with the Starfleet Meteorological Division.</p>
            </div>

            <form class="auth-form" method="post" autocomplete="off">
                <div class="auth-field">
                    <label class="auth-label" for="username">Username</label>
                    <input class="auth-input" type="text" id="username" name="Username" placeholder="Cadet handle" required />
                </div>

                <div class="auth-field">
                    <label class="auth-label" for="password">Password</label>
                    <input class="auth-input" type="password" id="password" name="Password" placeholder="••••••••" required />
                </div>

                <button type="submit" class="auth-submit">Login</button>
            </form>
        </div>
    </div>
</section>
